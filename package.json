{
	"name": "convly-studio",
	"private": true,
	"version": "0.1.0",
	"license": "UNLICENSED",
	"type": "module",
	"packageManager": "pnpm@10.18.1",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"release:verify": "pnpm run check && pnpm run test && pnpm run build && cargo check --manifest-path ./src-tauri/Cargo.toml",
		"release:build": "pnpm run release:verify && pnpm run tauri:build",
		"arch:build": "cd arch && makepkg --cleanbuild --clean --syncdeps --needed --noconfirm",
		"arch:install": "cd arch && makepkg --cleanbuild --clean --syncdeps --install --needed --noconfirm",
		"arch:uninstall": "sudo pacman -Rns --noconfirm convly-studio",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.43.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@tauri-apps/cli": "^2.10.0",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.544.0",
		"@tailwindcss/vite": "^4.1.14",
		"bits-ui": "^2.11.4",
		"clsx": "^2.1.1",
		"modern-screenshot": "^4.6.8",
		"mp4-muxer": "^5.2.2",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.1.1",
		"tailwindcss": "^4.1.14",
		"tw-animate-css": "^1.4.0",
		"webm-muxer": "^5.1.4"
	}
}
